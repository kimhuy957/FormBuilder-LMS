# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=formbuilder_lms
DB_USER=root
DB_PASSWORD=

# Application Configuration
APP_NAME="FormBuilder LMS"
APP_URL=http://localhost
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=UTC

# Security
APP_SECRET_KEY=your_secret_key_here_change_in_production
ENCRYPTION_KEY=your_encryption_key_here
CSRF_TOKEN_LENGTH=32

# Email Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@formbuilder-lms.com
MAIL_FROM_NAME="FormBuilder LMS"

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
UPLOAD_PATH=uploads/

# Pagination
ITEMS_PER_PAGE=10

# Authentication
PASSWORD_MIN_LENGTH=8
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=3600

# External Services (for future integrations)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=